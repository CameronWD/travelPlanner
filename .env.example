# Database — SQLite for local dev, replace with postgres:// in production
DATABASE_URL="file:./dev.db"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google OAuth credentials (from console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Application name shown in UI
NEXT_PUBLIC_APP_NAME="Trip Planner"

# Passwordless dev-login bypass. MUST stay "false" anywhere real (staging/prod).
# Set to "true" ONLY in local development to enable the quick traveller sign-in.
ALLOW_DEV_LOGIN="false"

# ---------------------------------------------------------------------------
# Web Push (VAPID) — optional. Without these, push notifications are disabled
# but the app works normally. Generate keys with: npx web-push generate-vapid-keys
# ---------------------------------------------------------------------------

# Server-side VAPID private key (keep secret — never expose to the browser)
VAPID_PRIVATE_KEY=""

# Server-side VAPID public key (must match NEXT_PUBLIC_VAPID_PUBLIC_KEY)
VAPID_PUBLIC_KEY=""

# VAPID subject: a mailto: or https: URI identifying your app
VAPID_SUBJECT="mailto:you@example.com"

# Browser-side VAPID public key (must match VAPID_PUBLIC_KEY above)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ---------------------------------------------------------------------------
# Cron secret — protects the /api/cron/reminders endpoint
# Without this, the endpoint returns 401 for all requests (fail-closed).
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET=""

# ---------------------------------------------------------------------------
# AI features (Anthropic) — optional
# Without ANTHROPIC_API_KEY the AI buttons are visible but disabled.
# Get a key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------

# Server-side Anthropic API key — never expose to the browser
ANTHROPIC_API_KEY=""

# Model to use for AI features (optional — defaults to claude-opus-4-8)
# Set to claude-sonnet-4-6 or claude-haiku-4-5 for lower cost
AI_MODEL=""

# ---------------------------------------------------------------------------
# Geocoding (OpenStreetMap Nominatim) — optional
# Nominatim's usage policy asks for a contact in the User-Agent. Set a real
# contact (email or app URL) for production; defaults to a placeholder.
# ---------------------------------------------------------------------------
NOMINATIM_CONTACT=""
