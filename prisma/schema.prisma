// Trip Planner — Prisma schema.
//
// All environments use Postgres: local dev runs a Postgres container via
// docker-compose; production uses Neon. To keep the schema portable:
//   * NO Prisma `enum`  — store enum-ish values as `String`, validate in app
//     code with the Zod unions in lib/enums.ts + lib/categories.ts.
//   * NO Prisma `Json`  — store JSON-ish data as a `String` of JSON.
// Money is `Int` minor units. Calendar dates are `String` "YYYY-MM-DD".
// Instants (transport dep/arr, timestamps) are `DateTime`. Lat/lng are `Float?`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7 no longer supports
  // `url` here). The PrismaClient is constructed with a driver adapter in
  // lib/db.ts.
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) models — standard shapes required by
// @auth/prisma-adapter. Do not rename fields.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  // Domain relations
  createdTrips     Trip[]            @relation("TripCreatedBy")
  forksCreated     Fork[]            @relation("ForkCreatedBy")
  memberships        TripMember[]
  notes              Note[]
  votes              Vote[]
  attachments        Attachment[]       @relation("AttachmentUploadedBy")
  assignedTasks      ChecklistItem[]    @relation("ChecklistAssignedTo")
  packingTemplates   PackingTemplate[]
  pushSubscriptions  PushSubscription[]
  journalEntries     JournalEntry[]
  activities         Activity[]
  globeMembership    GlobeMember?
  globesCreated      Globe[]       @relation("GlobeCreatedBy")
  markersCreated     Marker[]      @relation("MarkerCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domain models
// ---------------------------------------------------------------------------

model Trip {
  id           String @id @default(cuid())
  name         String
  startDate    String? // "YYYY-MM-DD" — null while the trip is a date-less idea
  endDate      String? // "YYYY-MM-DD" — soft; auto-extends to cover scheduled stops
  hardEndDate  String? // "YYYY-MM-DD" — optional traveller-set ceiling; never auto-extends (see ADR 0013)
  coverImageKey String? // storage key of the uploaded cover photo; null = use the route-render/monogram fallback
  homeCurrency String // ISO 4217, e.g. "AUD"

  // Per-trip driving-estimate settings (used by drive-time hints + the
  // "long driving day" flag). Defaults suit mixed/winding roads.
  drivingWindingFactor Float @default(1.5)
  drivingAvgSpeedKph   Int   @default(80)

  createdById  String

  createdBy User @relation("TripCreatedBy", fields: [createdById], references: [id])

  members        TripMember[]
  invites        Invite[]
  stops          Stop[]
  transports     Transport[]
  accommodations Accommodation[]
  items          Item[]
  costs          Cost[]
  exchangeRates  ExchangeRate[]
  notes          Note[]
  votes          Vote[]
  checklistItems ChecklistItem[]
  attachments    Attachment[]
  reminders      Reminder[]
  shareLink      ShareLink?
  calendarFeed   CalendarFeed?
  journalEntries JournalEntry[]
  chapters       Chapter[]
  activities     Activity[]

  forks          Fork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model Fork {
  id          String @id @default(cuid())
  tripId      String
  name        String
  sortOrder   Int    @default(0)
  createdById String

  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User @relation("ForkCreatedBy", fields: [createdById], references: [id])

  stops          Stop[]
  chapters       Chapter[]
  transports     Transport[]
  accommodations Accommodation[]
  items          Item[]
  costs          Cost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

model TripMember {
  id     String @id @default(cuid())
  tripId String
  userId String
  role   String // lib/enums.ts MEMBER_ROLES: "owner" | "member"

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadActivityAt DateTime?

  createdAt DateTime @default(now())

  @@unique([tripId, userId])
  @@index([userId])
}

model Invite {
  id         String    @id @default(cuid())
  tripId     String
  email      String
  token      String    @unique
  role       String    @default("member")
  acceptedAt DateTime?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tripId, email])
  @@index([tripId])
  @@index([email])
}

model Stop {
  id               String  @id @default(cuid())
  tripId           String
  forkId           String?
  name             String
  country          String?
  countryCode      String? // auto-derived ISO 3166-1 alpha-2 (lowercase, from Nominatim); null while un-derived
  lat              Float?
  lng              Float?
  timezone         String? // IANA — null while rough
  arriveDate       String? // "YYYY-MM-DD" — null while rough
  departDate       String? // "YYYY-MM-DD" — null while rough
  nights           Int?    // rough duration, used while rough
  sortOrder        Int
  pinned           Boolean @default(false) // dates fixed; ripple never moves it
  chapterId        String? // explicit chapter membership while rough
  chapterSortOrder Int     @default(0) // order within the chapter while rough
  notes            String?

  trip           Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fork           Fork?           @relation(fields: [forkId], references: [id], onDelete: Cascade)
  chapter        Chapter?        @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  accommodations Accommodation[]
  items          Item[]
  fromTransports Transport[]     @relation("TransportFromStop")
  toTransports   Transport[]     @relation("TransportToStop")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([forkId])
  @@index([chapterId])
}

model Chapter {
  id        String  @id @default(cuid())
  tripId    String
  forkId    String?
  name      String
  colour    String  // lib/chapter-colours.ts CHAPTER_COLOUR_VALUES
  startDate String? // "YYYY-MM-DD" — null while rough
  endDate   String? // "YYYY-MM-DD" — null while rough
  sortOrder Int     @default(0)

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fork  Fork?  @relation(fields: [forkId], references: [id], onDelete: Cascade)
  stops Stop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([forkId])
}

model Transport {
  id         String    @id @default(cuid())
  tripId     String
  forkId     String?
  fromStopId String?
  toStopId   String?
  mode       String // lib/enums.ts TRANSPORT_MODES
  depPlace   String?
  depAt      DateTime?
  arrPlace   String?
  arrAt      DateTime?
  depLat     Float?
  depLng     Float?
  arrLat     Float?
  arrLng     Float?
  reference  String?
  notes      String?
  sortOrder  Int       @default(0)

  trip     Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fork     Fork? @relation(fields: [forkId], references: [id], onDelete: Cascade)
  fromStop Stop? @relation("TransportFromStop", fields: [fromStopId], references: [id], onDelete: SetNull)
  toStop   Stop? @relation("TransportToStop", fields: [toStopId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([forkId])
}

model Accommodation {
  id           String  @id @default(cuid())
  tripId       String
  forkId       String?
  stopId       String
  name         String
  address      String?
  checkIn      String // "YYYY-MM-DD"
  checkOut     String // "YYYY-MM-DD"
  confirmation String?
  notes        String?
  lat          Float?
  lng          Float?

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fork Fork? @relation(fields: [forkId], references: [id], onDelete: Cascade)
  stop Stop  @relation(fields: [stopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([forkId])
  @@index([stopId])
}

model Item {
  id        String  @id @default(cuid())
  tripId    String
  forkId    String?
  stopId    String?
  title     String
  category  String // lib/categories.ts CATEGORY_VALUES
  date      String? // "YYYY-MM-DD" — null = unscheduled (wishlist)
  startTime String? // "HH:mm" in the stop's local timezone
  endTime   String? // "HH:mm"
  lat       Float?
  lng       Float?
  address   String?
  link      String?
  booking   String?
  notes     String?
  sortOrder      Int     @default(0)
  sourceItemId   String?
  sourceMarkerId String?

  trip         Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fork         Fork?   @relation(fields: [forkId], references: [id], onDelete: Cascade)
  stop         Stop?   @relation(fields: [stopId], references: [id], onDelete: SetNull)
  sourceItem   Item?   @relation("ItemPlacedFrom", fields: [sourceItemId], references: [id], onDelete: SetNull)
  placements   Item[]  @relation("ItemPlacedFrom")
  sourceMarker Marker? @relation("ItemFromMarker", fields: [sourceMarkerId], references: [id], onDelete: SetNull)
  votes        Vote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([forkId])
  @@index([stopId])
  @@index([sourceItemId])
  @@index([sourceMarkerId])
}

model Cost {
  id             String    @id @default(cuid())
  tripId         String
  forkId         String?
  estimatedMinor Int // minor units, always present
  actualMinor    Int? // minor units, optional
  currency       String // ISO 4217
  rateToHome     Float? // snapshotted FX rate at entry, or null if same currency
  paidAt         DateTime?
  ownerType      String // lib/enums.ts COST_OWNER_TYPES
  ownerId        String? // null when ownerType == OTHER
  label          String? // names an OTHER cost (e.g. "Travel insurance")
  category       String?

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fork Fork? @relation(fields: [forkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([forkId])
  @@index([ownerType, ownerId])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  tripId    String
  base      String // ISO 4217
  quote     String // ISO 4217
  rate      Float
  fetchedAt DateTime
  manual    Boolean  @default(false)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, base, quote])
  @@index([tripId])
}

model Note {
  id         String @id @default(cuid())
  tripId     String
  authorId   String
  targetType String // lib/enums.ts TARGET_TYPES
  targetId   String
  body       String

  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tripId])
  @@index([targetType, targetId])
}

model Vote {
  id     String @id @default(cuid())
  tripId String
  itemId String
  userId String
  level  String // lib/enums.ts VOTE_LEVELS

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tripId, itemId, userId])
  @@index([itemId])
}

model ChecklistItem {
  id           String  @id @default(cuid())
  tripId       String
  kind         String // lib/enums.ts CHECKLIST_KINDS
  text         String
  done         Boolean @default(false)
  dueDate      String? // "YYYY-MM-DD"
  sortOrder    Int     @default(0)
  assignedToId String?

  trip       Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("ChecklistAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

model Attachment {
  id           String  @id @default(cuid())
  tripId       String
  targetType   String // lib/enums.ts TARGET_TYPES
  targetId     String?
  filename     String
  mime         String
  size         Int
  url          String // public serve path: /api/attachments/<id>
  storageKey   String? // opaque key used by the Storage abstraction
  uploadedById String

  trip       Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tripId])
  @@index([targetType, targetId])
}

model PackingTemplate {
  id        String @id @default(cuid())
  ownerId   String
  name      String
  itemsJson String // JSON-encoded array of template items (schema avoids Prisma Json by design)

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Reminder {
  id         String   @id @default(cuid())
  tripId     String
  title      String
  fireAt     DateTime
  sent       Boolean  @default(false)
  targetType String?
  targetId   String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tripId])
}

model ShareLink {
  id        String   @id @default(cuid())
  tripId    String   @unique
  token     String   @unique
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model CalendarFeed {
  id        String   @id @default(cuid())
  tripId    String   @unique
  token     String   @unique
  createdAt DateTime @default(now())

  // Which event types this feed publishes. All default true so existing
  // feeds keep publishing everything until a member narrows them.
  includeTransport     Boolean @default(true)
  includeAccommodation Boolean @default(true)
  includeActivities    Boolean @default(true)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JournalEntry {
  id       String @id @default(cuid())
  tripId   String
  date     String // "YYYY-MM-DD"
  body     String
  authorId String

  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, date])
  @@index([tripId])
}

model Activity {
  id          String   @id @default(cuid())
  tripId      String
  actorId     String
  verb        String // CREATED | UPDATED | DELETED | NOTED
  entityType  String // STOP | ITEM | TRANSPORT | ACCOMMODATION | CHAPTER | COST | NOTE
  entityId    String?
  entityLabel String // snapshot so deleted entities still render
  changes     Json? // [{ field, label, from, to }] for UPDATED; { excerpt } for NOTED
  createdAt   DateTime @default(now())

  trip  Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}

// ---------------------------------------------------------------------------
// The Globe — a single shared, cross-trip collection of places to visit.
// Account-level aggregate, decoupled from Trip (see ADR 0023). Rendered as a
// flat Leaflet map (see ADR 0024).
// ---------------------------------------------------------------------------

model Globe {
  id          String @id @default(cuid())
  createdById String

  createdBy User          @relation("GlobeCreatedBy", fields: [createdById], references: [id])
  members   GlobeMember[]
  markers   Marker[]
  invites   GlobeInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model GlobeMember {
  id      String @id @default(cuid())
  globeId String
  userId  String
  role    String // lib/enums.ts MEMBER_ROLES: "owner" | "member"

  globe Globe @relation(fields: [globeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // A user belongs to at most one Globe (ADR 0023) — enforced globally, not
  // just per-globe, so a userId appears in exactly one GlobeMember row.
  @@unique([userId])
  @@index([globeId])
}

model GlobeInvite {
  id         String    @id @default(cuid())
  globeId    String
  email      String
  token      String    @unique
  role       String    @default("member")
  acceptedAt DateTime?

  globe Globe @relation(fields: [globeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([globeId, email])
  @@index([globeId])
  @@index([email])
}

model Marker {
  id          String  @id @default(cuid())
  globeId     String
  title       String
  category    String // lib/categories.ts CATEGORY_VALUES
  note        String?
  link        String?
  timing      String? // rough free-text "when" (e.g. "late Sept") — never a scheduled date
  lat         Float?
  lng         Float?
  city        String? // auto-derived town/city
  country     String? // auto-derived country name
  countryCode String? // auto-derived ISO 3166-1 alpha-2 (lowercase, from Nominatim)
  createdById String

  globe          Globe  @relation(fields: [globeId], references: [id], onDelete: Cascade)
  createdBy      User   @relation("MarkerCreatedBy", fields: [createdById], references: [id])
  wishlistCopies Item[] @relation("ItemFromMarker")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([globeId])
  @@index([createdById])
}
